sigma= np.cov(x,y) #covariance matrix of aapl and msft
rho= np.corrcoef(x,y) #correlation matrix
xmean= np.mean(x)
ymean= np.mean(y)
xstd= np.std(x)
ystd= np.std(y)
z=[]
k=[]
for i in x:
  l= i - xmean  #each datapoints distance from the mean
  l= l/xstd  # this turns it into zscores, normalised stdsfrom the mean
  k.append(l)
for i in y:
  j= i - ymean
  j= j/ ystd
  z.append(j)
#plot scatterplot var  and cov
plt.figure(figsize= (8,6))
dw = np.array(k)
ds= np.array(z)
idea= abs(ds)+abs(dw) #this is a colormap to aid reading of the plot
"""the simple rule is that the lighter the rarer the darker the more typical"""
plt.scatter(k,z,cmap="hot", alpha= 0.7, c= idea) ; plt.axvline(0, linewidth= 0.2, color= "black") ; plt.axhline(0, linewidth= 0.2, color= "black")
plt.text(4,3.5,f"Σ: {sigma}\n\nρ: {rho}")
plt.xlabel("AAPL daily percentage return devation in terms of σ")
plt.ylabel("MSFT daily percentage return deviation in terms of σ")
plt.title("AAPL & MSFT Scatterplot of variance and covariance")
plt.legend()
#fitting a line
sigma2= np.cov(k,z)
val, vec= np.linalg.eigh(sigma2)
vecs= vec[:,np.argmax(val)]  #find the eigenvector of greatest eigenvalue, that is pc1
vecs2= vec[:,np.argmin(val)]
slope= vecs[1]/vecs[0]
slope2= vecs2[1]/vecs2[0]
X= np.linspace(np.min(k),np.max(k),500)
y= slope*X #y=mx
Y= slope2*X
plt.plot(X,y, color= "purple", linewidth= 3, linestyle= "dashed", label= "pc1")
plt.plot(X,Y,color= "purple", linewidth= 2, label= "pc2")
plt.legend()
plt.show()
#express the plot in terms of the new eigenbases pc1&2
s= np.column_stack([k,z])
Q= vec
S= s @ Q
plt.figure(figsize= (8,6)) ; plt.xlabel("pc1(co-move score)") ; plt.ylabel("pc2 (divergence score)") ; plt.title(" Eigenbasis in terms of pc1&2")

com= S[:,1]
div= S[:,0]
com1= np.abs(com)
com2= (com1 + 1e-10) / max(com1)   #com stands for co-move

div1= np.abs(div)
div2= (div1 + 1e-10) / max(div1)   #com stands for co-move

rule=com2 - div2
plt.scatter( S[:,1], S[:,0], c=rule, alpha= 0.7, cmap= "hot")
#plt.text(3.25,3.5,f"New Σ: {vec}")
plt.axvline(0, linewidth= 2.5, color= "purple", label= "pc2") ; plt.axhline(0, linewidth= 3,color="purple",label= "pc1", linestyle= "--") ;plt.legend(); plt.show()
# variance ratios
print(f"pc1 variance ratio: {(val[0]/(val[0]+val[1]))*100}%")
print(f"pc2 variance ratio: {(val[1]/(val[0]+val[1]))*100}%")

