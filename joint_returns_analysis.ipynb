kde= gaussian_kde(z)
y1= np.linspace(z.min(),z.max(),300)
x1= kde(y1)
plt.plot(y1,x1, color= "black", alpha= 0.5)
k= np.array(k)
kde= gaussian_kde(k)
y2= np.linspace(k.min(),k.max(),300)
x2= kde(y2)
plt.plot(y2,x2, color= "green", alpha= 0.5)

plt.ylabel("height(freq)")
plt.xlabel("returns in terms of z score\n(standard deviations from the mean)")
plt.title("Histograms for comparison\n(σ is 1)")
plt.show()


#mvn
#3d histogram of joint returns of aapl and msft, here the height is the probability density
#the lower each datapoint is from the peak the less probable that joint return is
import plotly.graph_objects as go
from scipy.stats import multivariate_normal
pic= go.Figure()
nu=500
xx= np.linspace(k.min(),k.max(),nu)
yy= np.linspace(z.min(),z.max(),nu)
xx1, yy1= np.meshgrid(xx,yy) #zz stands for the z 3rd axis
mvn= multivariate_normal((xmean,ymean),sigma2)
dstacked= np.dstack((xx1,yy1))
zz= mvn.pdf(dstacked)
pts= np.column_stack([k,z])
zzz= mvn.pdf(pts)
pic.add_trace(go.Scatter3d(x=k, y=z, z= zzz,  mode= "markers", marker= dict(size= 2.5, color= "green")))

dayno= np.arange(1,k.size+2)
print(k.size)
pic.add_trace(go.Surface(x= xx1, y=yy1, z= zz, opacity= 0.7, colorscale= "Plasma", hovertemplate= "Day %{}<br>Scenario %{y}<br>Value %{z}<extra></extra>",contours= dict(z=dict(show= True,usecolormap= False, project= dict(z= True)))))
pic.add_trace(go.Scatter3d(x=k, y=z, z= np.zeros_like(k.flatten()), mode= "markers", marker= dict(size= 2.5, opacity= 0.6, color= "purple")))
pic.update_layout(
    title="Interactive 3D histogram showing joint returns for (k, z)",
    scene=dict(
        xaxis_title="k (AAPL z-score)",  #some adjustments
        yaxis_title="z (MSFT z-score)",
        zaxis_title="density f(k,z)",
        # makes it feel less like a bland cone: better proportions + view angle
        aspectmode="manual",
        aspectratio=dict(x=1.1, y=1.1, z=0.7),
        camera=dict(eye=dict(x=1.6, y=1.6, z=0.9))
    ),
    legend=dict(x=0.02, y=0.98),
    height=800
)
pic.show()
